# Copy to .env.local (or .env.production.local) before `npm run cap:sync:android`
# Values are baked into the static build at compile time.

# Production / hosted backend (recommended for release APK)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=https://your-api.example.com/api/v1

# --- Local dev on Android emulator (optional) ---
# Emulator cannot reach host "localhost"; use 10.0.2.2 instead.
# NEXT_PUBLIC_SUPABASE_URL=http://10.0.2.2:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEXT_PUBLIC_API_URL=http://10.0.2.2:8000/api/v1
